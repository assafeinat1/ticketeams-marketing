{
  "version": "1.0.0",
  "mondayApprovalBoard": {
    "boardId": null,
    "groupId": "orchestrator_approvals",
    "columns": {
      "status": "status",
      "approvalType": "text_approval_type",
      "eventName": "text_event_name",
      "heatScore": "numbers_heat_score",
      "suggestedBudget": "numbers_budget",
      "targeting": "text_targeting",
      "roas": "numbers_roas",
      "agentSource": "text_agent_source",
      "reason": "long_text_reason",
      "createdAt": "date_created",
      "decidedAt": "date_decided",
      "decisionJson": "long_text_decision"
    },
    "statusLabels": {
      "pending": "ממתין לאישור",
      "approved": "אושר",
      "rejected": "נדחה",
      "autoExecuted": "בוצע אוטומטית"
    }
  },
  "decisionRules": {
    "autoActions": ["LOG_ONLY", "FLAG_IN_REPORT", "ALERT_ONLY"],
    "thresholds": {
      "hotEventMinScore": 36,
      "onFireMinScore": 61,
      "createCampaignMinScore": 60,
      "requireEventOnSite": true,
      "roasPauseThreshold": 1.0,
      "roasPauseDaysMin": 3,
      "roasReduceThreshold": 1.5,
      "roasReduceDaysMin": 5,
      "roasBoostThreshold": 5.0,
      "roasBoostDaysMin": 3,
      "budgetReductionFactor": 0.5,
      "budgetIncreaseFactor": 1.3,
      "daysBeforeGameAdWindow": [28, 42],
      "daysBeforeGameUrgent": 7,
      "budgetBurnPctAlert": 80,
      "budgetBurnBeforeHourUTC": 12,
      "zeroImpressionsAfterHours": 6
    }
  },
  "scheduling": {
    "hotEventCheck": "15 4 * * *",
    "performanceMonitor": "0 */6 * * *",
    "comment": "hotEventCheck at 04:15 UTC = 07:15 IST (15min after intelligence). performanceMonitor every 6 hours."
  },
  "budgetDefaults": {
    "baseDailyBudget": 150,
    "hotEventMultiplier": 1.5,
    "onFireMultiplier": 2.0,
    "currency": "ILS"
  },
  "notifications": {
    "emailTo": "assafeinat1@gmail.com",
    "mondayUpdateOnDecision": true,
    "logToCache": true
  },
  "cache": {
    "directory": "orchestrator",
    "ttlHours": 12
  }
}
